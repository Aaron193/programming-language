{
  "scopeName": "source.mog",
  "name": "Mog",
  "patterns": [
    {
      "name": "comment.block.mog",
      "begin": "/\\*",
      "end": "\\*/"
    },
    {
      "name": "comment.line.double-slash.mog",
      "match": "//.*$"
    },
    {
      "name": "string.quoted.double.mog",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.mog",
          "match": "\\\\."
        }
      ]
    },
    {
      "name": "constant.numeric.mog",
      "match": "\\b\\d+(?:\\.\\d+)?(?:usize|i8|i16|i32|i64|u|u8|u16|u32|u64|f32|f64)?\\b"
    },
    {
      "name": "constant.language.boolean.mog",
      "match": "\\b(?:true|false|null)\\b"
    },
    {
      "name": "keyword.control.import.mog",
      "match": "@import\\b"
    },
    {
      "name": "storage.modifier.annotation.mog",
      "match": "@operator\\b"
    },
    {
      "include": "#type-context-expression"
    },
    {
      "match": "\\b(type)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
      "captures": {
        "1": {
          "name": "keyword.control.mog"
        },
        "2": {
          "name": "entity.name.type.mog"
        }
      }
    },
    {
      "match": "\\b(fn)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
      "captures": {
        "1": {
          "name": "keyword.control.mog"
        },
        "2": {
          "name": "entity.name.function.mog"
        }
      }
    },
    {
      "match": "\\b(const)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
      "captures": {
        "1": {
          "name": "keyword.control.mog"
        },
        "2": {
          "name": "variable.other.constant.mog"
        }
      }
    },
    {
      "match": "\\b(var)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
      "captures": {
        "1": {
          "name": "keyword.control.mog"
        },
        "2": {
          "name": "variable.other.readwrite.mog"
        }
      }
    },
    {
      "name": "keyword.control.mog",
      "match": "\\b(?:var|const|fn|type|struct|if|else|for|while|break|continue|this|super|return|as)\\b"
    },
    {
      "include": "#type-angle-expression"
    },
    {
      "name": "entity.name.type.mog",
      "match": "\\b(?:i8|i16|i32|i64|u8|u16|u32|u64|u|usize|f32|f64|bool|str|void|null|fn)\\b"
    },
    {
      "name": "entity.name.function.method.mog",
      "match": "(?<=\\.)[a-z_][A-Za-z0-9_]*\\b(?=\\s*\\()"
    },
    {
      "name": "variable.other.property.mog",
      "match": "(?<=\\.)[a-z_][A-Za-z0-9_]*\\b"
    },
    {
      "name": "entity.name.function.mog",
      "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b(?=\\s*\\()"
    },
    {
      "name": "keyword.operator.mog",
      "match": "(?:\\+\\+|--|&&|\\|\\||==|!=|<=|>=|<<=|>>=|<<|>>|=>|\\+=|-=|\\*=|/=|&=|\\|=|\\^=|[+\\-*/&|^~<>!=?:.])"
    },
    {
      "name": "punctuation.separator.mog",
      "match": "[,;]"
    },
    {
      "name": "punctuation.section.group.begin.mog",
      "match": "[\\[{(]"
    },
    {
      "name": "punctuation.section.group.end.mog",
      "match": "[\\]})]"
    }
  ],
  "repository": {
    "type-context-expression": {
      "patterns": [
        {
          "match": "\\b(var|const)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "keyword.control.mog"
            },
            "2": {
              "name": "variable.other.readwrite.mog"
            },
            "3": {
              "name": "entity.name.type.mog"
            }
          }
        },
        {
          "match": "\\b(?!(?:as|print|var|const|fn|type|struct|if|else|for|while|break|continue|this|super|return)\\b)([A-Za-z_][A-Za-z0-9_]*)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b(?=\\s*(?:,|\\)|:))",
          "captures": {
            "1": {
              "name": "variable.parameter.mog"
            },
            "2": {
              "name": "entity.name.type.mog"
            }
          }
        },
        {
          "match": "\\b(?!(?:as|print|var|const|fn|type|struct|if|else|for|while|break|continue|this|super|return)\\b)([A-Za-z_][A-Za-z0-9_]*)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b(?=\\s*$)",
          "captures": {
            "1": {
              "name": "variable.parameter.mog"
            },
            "2": {
              "name": "entity.name.type.mog"
            }
          }
        },
        {
          "match": "(\\))\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "punctuation.section.group.end.mog"
            },
            "2": {
              "name": "entity.name.type.mog"
            }
          }
        }
      ]
    },
    "type-angle-expression": {
      "patterns": [
        {
          "name": "meta.type.generic.collection.mog",
          "begin": "\\b(Array|Set|Dict)\\s*(<)",
          "beginCaptures": {
            "1": {
              "name": "entity.name.type.mog"
            },
            "2": {
              "name": "punctuation.section.group.begin.mog"
            }
          },
          "end": "(>)",
          "endCaptures": {
            "1": {
              "name": "punctuation.section.group.end.mog"
            }
          },
          "patterns": [
            {
              "include": "#type-angle-expression"
            },
            {
              "name": "punctuation.separator.mog",
              "match": ","
            },
            {
              "name": "entity.name.type.mog",
              "match": "\\b(?:i8|i16|i32|i64|u8|u16|u32|u64|u|usize|f32|f64|bool|str|void|null|fn)\\b"
            },
            {
              "name": "entity.name.type.mog",
              "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
            }
          ]
        },
        {
          "name": "meta.type.native-handle.mog",
          "begin": "\\b(handle)\\s*(<)",
          "beginCaptures": {
            "1": {
              "name": "entity.name.type.mog"
            },
            "2": {
              "name": "punctuation.section.group.begin.mog"
            }
          },
          "end": "(>)",
          "endCaptures": {
            "1": {
              "name": "punctuation.section.group.end.mog"
            }
          },
          "patterns": [
            {
              "name": "punctuation.separator.mog",
              "match": ":"
            },
            {
              "name": "entity.name.type.mog",
              "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
            },
            {
              "name": "variable.other.readwrite.mog",
              "match": "\\b[a-z_][A-Za-z0-9_]*\\b"
            }
          ]
        }
      ]
    }
  }
}
