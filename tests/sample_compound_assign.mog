var x i32 = 10
x += 5
print(x)

x -= 3
print(x)

x *= 2
print(x)

x /= 4
print(x)

x <<= 3
print(x)

x >>= 2
print(x)

x++
print(x)

++x
print(x)

x--
print(x)

--x
print(x)

type Box struct {
	value i32
}
var b Box = Box()
b.value = 7
b.value += 5
print(b.value)

b.value--
print(b.value)

++b.value
print(b.value)
