const window = @import("window")

const win window.Window =
    window.create("Demo", 64i64, 64i64)
const evt window.Event? = window.pollEvent(win)

window.clear(win)
window.present(win)

print(evt == null)
print(window.mouseX(win) >= 0i64)
print(window.mouseY(win) >= 0i64)
print(window.isKeyDown(win, 13i64))

window.close(win)
