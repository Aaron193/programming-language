class Node {
  i32 value;
  Node next;
}

f64 start = clock();

Node head = Node();
head.value = 1;
head.next = head;

Node tail = head;
for (i32 i = 2; i <= 100000; i++) {
  Node node = Node();
  node.value = i;
  node.next = head;
  tail.next = node;
  tail = node;
}

i64 sum = 0;
Node current = head;
for (i32 steps = 0; steps < 100000; steps++) {
  sum += current.value;
  current = current.next;
}

f64 elapsed = clock() - start;

print(sum);
print(elapsed);
