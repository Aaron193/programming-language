class Base {
  greet() -> str {
    return "base";
  }
}

class Derived < Base {
  str label;

  greet() -> str {
    return super.greet() + "-" + this.label;
  }
}

Derived d = Derived();
d.label = "derived";
print(d.greet());

fn() -> str extracted = d.greet;
print(extracted());

Array<i32> values = [1i32, 2i32];
print(values.size());
values.push(3i32);
print(values.size());
