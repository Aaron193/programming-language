fn require(condition bool, message str) void {
    if (!condition) {
        error(message)
    }
}

var WINDOW_WIDTH i64 = 800i64
var WINDOW_HEIGHT i64 = 600i64
var BIRD_X i64 = 160i64
var BIRD_WIDTH i64 = 34i64
var BIRD_HEIGHT i64 = 24i64
var PIPE_WIDTH i64 = 80i64
var PIPE_GAP i64 = 180i64
var GROUND_HEIGHT i64 = 100i64

var FIXED_DT f64 = 1.0 / 60.0
var GRAVITY f64 = 1400.0
var FLAP_IMPULSE f64 = -350.0
var PIPE_SPEED f64 = 180.0
var SPAWN_INTERVAL f64 = 1.4

type Pipe struct {
    x f64
    gapY f64
    passed bool
}

type GameState struct {
    birdY f64
    birdVelocity f64
    pipes Array<Pipe>
    spawnTimer f64
    spawnIndex i32
    score i32
    running bool
    dead bool
}

fn makePipe(x f64, gapY f64) Pipe {
    var pipe Pipe = Pipe()
    pipe.x = x
    pipe.gapY = gapY
    pipe.passed = false
    return pipe
}

fn nextGapY(spawnIndex i32) f64 {
    var cycle i32 = spawnIndex
    while (cycle >= 8) {
        cycle = cycle - 8
    }

    if (cycle == 0) {
        return 180.0
    }
    if (cycle == 1) {
        return 260.0
    }
    if (cycle == 2) {
        return 320.0
    }
    if (cycle == 3) {
        return 230.0
    }
    if (cycle == 4) {
        return 150.0
    }
    if (cycle == 5) {
        return 300.0
    }
    if (cycle == 6) {
        return 210.0
    }

    return 280.0
}

fn spawnPipe(state GameState, x f64) void {
    var pipe Pipe = makePipe(x, nextGapY(state.spawnIndex))
    state.spawnIndex = state.spawnIndex + 1
    state.pipes.push(pipe)
}

fn seedInitialPipes(state GameState) void {
    spawnPipe(state, 500.0)
    spawnPipe(state, 500.0 + (PIPE_SPEED * SPAWN_INTERVAL))
}

fn resetGame() GameState {
    var state GameState = GameState()
    var pipes Array<Pipe> = []

    state.birdY = 220.0
    state.birdVelocity = 0.0
    state.pipes = pipes
    state.spawnTimer = 0.0
    state.spawnIndex = 0
    state.score = 0
    state.running = true
    state.dead = false

    seedInitialPipes(state)
    return state
}

fn updatePipes(state GameState, dt f64) void {
    var activePipes Array<Pipe> = []
    var index i32 = 0

    while ((index as f64) < state.pipes.size()) {
        var pipe Pipe = state.pipes[index]
        pipe.x = pipe.x - (PIPE_SPEED * dt)
        if ((pipe.x + PIPE_WIDTH) > 0.0) {
            activePipes.push(pipe)
        }

        index = index + 1
    }

    state.pipes = activePipes
    state.spawnTimer = state.spawnTimer + dt

    while (state.spawnTimer >= SPAWN_INTERVAL) {
        state.spawnTimer = state.spawnTimer - SPAWN_INTERVAL
        spawnPipe(state, WINDOW_WIDTH + PIPE_WIDTH)
    }
}

fn updateScore(state GameState) void {
    var index i32 = 0
    while ((index as f64) < state.pipes.size()) {
        var pipe Pipe = state.pipes[index]
        if (pipe.passed == false &&
            (pipe.x + PIPE_WIDTH) < BIRD_X) {
            pipe.passed = true
            state.score = state.score + 1
        }

        index = index + 1
    }
}

fn checkCollisions(state GameState) bool {
    var birdLeft f64 = BIRD_X
    var birdRight f64 = birdLeft + BIRD_WIDTH
    var birdTop f64 = state.birdY
    var birdBottom f64 = state.birdY + BIRD_HEIGHT
    var groundTop f64 = WINDOW_HEIGHT - GROUND_HEIGHT
    var halfGap f64 = PIPE_GAP / 2.0

    if (birdTop < 0.0) {
        return true
    }

    if (birdBottom >= groundTop) {
        return true
    }

    var index i32 = 0
    while ((index as f64) < state.pipes.size()) {
        var pipe Pipe = state.pipes[index]
        var pipeLeft f64 = pipe.x
        var pipeRight f64 = pipe.x + PIPE_WIDTH
        if (birdRight > pipeLeft && birdLeft < pipeRight) {
            var gapTop f64 = pipe.gapY - halfGap
            var gapBottom f64 = pipe.gapY + halfGap
            if (birdTop < gapTop || birdBottom > gapBottom) {
                return true
            }
        }

        index = index + 1
    }

    return false
}

fn updateBird(state GameState, flapPressed bool, dt f64) void {
    if (flapPressed) {
        state.birdVelocity = FLAP_IMPULSE
    }

    state.birdVelocity = state.birdVelocity + (GRAVITY * dt)
    state.birdY = state.birdY + (state.birdVelocity * dt)
}

fn stepGame(state GameState, flapPressed bool, dt f64) void {
    if (state.running == false) {
        return
    }

    updateBird(state, flapPressed, dt)
    updatePipes(state, dt)
    updateScore(state)

    if (checkCollisions(state)) {
        state.birdVelocity = 0.0
        state.running = false
        state.dead = true
    }
}

var state GameState = resetGame()
require(state.running, "game should start running")
require(state.dead == false, "game should start alive")
require(state.score == 0, "score should start at zero")

var pipeCount i32 = 0
for (var pipe Pipe : state.pipes) {
    pipeCount = pipeCount + 1
}
require(pipeCount == 2, "initial pipe seed should create two pipes")

var startX f64 = state.pipes[0].x
updatePipes(state, 0.5)
require(state.pipes[0].x < startX, "pipe should move left")

state.pipes[0].x = BIRD_X - PIPE_WIDTH - 5.0
updateScore(state)
require(state.score == 1, "passing a pipe should increment score")

updateScore(state)
require(state.score == 1, "score should only increment once per pipe")

state = resetGame()
state.birdY = -1.0
require(checkCollisions(state), "bird above the ceiling should collide")

state = resetGame()
state.birdY =
    ((WINDOW_HEIGHT - GROUND_HEIGHT - BIRD_HEIGHT) as f64) + 2.0
require(checkCollisions(state), "bird touching ground should collide")

state = resetGame()
state.birdY =
    ((WINDOW_HEIGHT - GROUND_HEIGHT - BIRD_HEIGHT) as f64) + 2.0
stepGame(state, false, FIXED_DT)
require(state.dead, "collision should mark game dead")
require(state.running == false, "collision should stop simulation")

print("ok")
