const first = @import("./modules/cache_handle_target.mog")
const second = @import("./modules/cache_handle_target.mog")
const third = @import("./modules/cache_handle_target.mog")

var total i64 = 0i64
var i i64 = 0i64
while (i < 50i64) {
  const handle handle<examples:counter:CounterHandle> = first.Make(i)
  total = total + second.Read(handle)
  total = total + third.Add(handle, 2i64)
  i = i + 1i64
}

print(total)
