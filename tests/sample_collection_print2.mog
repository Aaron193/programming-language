var a Array<i32> = [1, 2, 3]
print(a.first())
print(a.last())
print(a.isEmpty())
print(a.clear())
print(a.isEmpty())

var d Dict<str, i32> = {"x": 1}
print(d.getOr("x", 0))
print(d.getOr("missing", 7))
print(d.isEmpty())
print(d.clear())
print(d.isEmpty())

var left Set<i32> = Set(1, 2, 3)
var right Set<i32> = Set(3, 4)
print(left.union(right))
print(left.intersect(right))
print(left.difference(right))
print(left.isEmpty())
print(left.clear())
print(left.isEmpty())
