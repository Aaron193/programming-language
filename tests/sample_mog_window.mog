const window = @import("window")

const win handle<window:WindowHandle> =
    window.create("Demo", 64i64, 64i64)
const evt handle<window:EventHandle>? = window.pollEvent(win)

window.clear(win)
window.present(win)

print(evt == null)
print(window.mouseX(win) >= 0i64)
print(window.mouseY(win) >= 0i64)
print(window.isKeyDown(win, 13i64))

window.close(win)
