---
import '../styles/site.css';

interface Props {
	title: string;
	description: string;
	path?: string;
	variant?: 'default' | 'landing';
}

const { title, description, path = '/', variant = 'default' } = Astro.props;
const site = Astro.site ?? new URL('https://moglang.dev');
const canonical = new URL(path, site).toString();
const isLanding = variant === 'landing';
const bodyClass = ['site-shell', isLanding ? 'site-shell--landing' : ''].filter(Boolean).join(' ');
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{title} | Mog</title>
		<meta name="description" content={description} />
		{
			isLanding ? (
				<>
					<meta id="theme-color-meta" name="theme-color" content="#f7faf7" />
					<script is:inline>
						(() => {
							const storageKey = 'mog-landing-theme-mode';
							const root = document.documentElement;
							const themeColorMeta = document.getElementById('theme-color-meta');
							const darkQuery = window.matchMedia('(prefers-color-scheme: dark)');
							const normalizeMode = (value) =>
								value === 'light' || value === 'dark' || value === 'system' ? value : 'system';
							const resolveTheme = (mode) =>
								mode === 'light' ? 'light' : mode === 'dark' ? 'dark' : darkQuery.matches ? 'dark' : 'light';

							window.__mogThemeMode = {
								apply(mode) {
									const nextMode = normalizeMode(mode);
									const resolvedTheme = resolveTheme(nextMode);
									root.dataset.themeMode = nextMode;
									root.dataset.themeResolved = resolvedTheme;
									root.style.colorScheme = resolvedTheme;

									if (themeColorMeta) {
										themeColorMeta.setAttribute('content', resolvedTheme === 'dark' ? '#061311' : '#f7faf7');
									}
								},
								read() {
									try {
										return normalizeMode(window.localStorage.getItem(storageKey));
									} catch {
										return 'system';
									}
								},
								write(mode) {
									try {
										window.localStorage.setItem(storageKey, normalizeMode(mode));
									} catch {
										return;
									}
								},
							};

							window.__mogThemeMode.apply(window.__mogThemeMode.read());
						})();
					</script>
				</>
			) : (
				<meta name="theme-color" content="#061311" />
			)
		}
		<link rel="canonical" href={canonical} />
		<meta property="og:title" content={`${title} | Mog`} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonical} />
		<meta name="twitter:card" content="summary_large_image" />
		<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
	</head>
	<body class={bodyClass}>
		<header class="topbar">
			<div class="topbar__inner">
				<a class="brand" href="/">
					<img src="/favicon.svg" alt="Mog" />
					<span>
						Mog
						<small>Strict by default. Fast on purpose.</small>
					</span>
				</a>
				<nav class="topnav" aria-label="Primary">
					<a href="/docs/">Docs</a>
					<a href="/manifesto/">Manifesto</a>
					<a href="/docs/reference/syntax-rules/">Reference</a>
					<a class="cta" href="/docs/getting-started/quickstart/">Start Building</a>
					{
						isLanding && (
							<label class="theme-select" data-theme-icon="system">
								<span class="theme-select__icon" aria-hidden="true">
									<svg class="theme-select__glyph theme-select__glyph--system" viewBox="0 0 16 16" fill="none">
										<rect x="2.25" y="3" width="11.5" height="7.75" rx="1.5" stroke="currentColor" stroke-width="1.25"></rect>
										<path d="M6 13h4" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"></path>
									</svg>
									<svg class="theme-select__glyph theme-select__glyph--dark" viewBox="0 0 16 16" fill="none">
										<path
											d="M10.9 2.2a5.8 5.8 0 1 0 2.9 10.8A6.4 6.4 0 0 1 10.9 2.2Z"
											stroke="currentColor"
											stroke-width="1.25"
											stroke-linejoin="round"
										></path>
									</svg>
									<svg class="theme-select__glyph theme-select__glyph--light" viewBox="0 0 16 16" fill="none">
										<circle cx="8" cy="8" r="2.75" stroke="currentColor" stroke-width="1.25"></circle>
										<path d="M8 1.75v1.5M8 12.75v1.5M14.25 8h-1.5M3.25 8h-1.5M12.42 3.58 11.36 4.64M4.64 11.36 3.58 12.42M12.42 12.42 11.36 11.36M4.64 4.64 3.58 3.58" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"></path>
									</svg>
								</span>
								<select class="theme-select__input" data-theme-select aria-label="Landing page theme">
									<option value="system">System</option>
									<option value="dark">Dark</option>
									<option value="light">Light</option>
								</select>
								<svg class="theme-select__caret" aria-hidden="true" viewBox="0 0 16 16" fill="none">
									<path d="m4.25 6.5 3.75 3.75 3.75-3.75" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
								</svg>
							</label>
						)
					}
				</nav>
			</div>
		</header>
		<main>
			<slot />
		</main>
		<footer class="footer">
			<div class="footer__inner">
				<p>Mog is a bytecode-compiled language project implemented in C++ with official docs in Astro + Starlight.</p>
				<div class="footer__links">
					<a href="/docs/">Docs</a>
					<a href="/manifesto/">Manifesto</a>
					<a href="/docs/reference/syntax-rules/">Reference</a>
				</div>
			</div>
		</footer>
		{
			isLanding && (
				<script is:inline>
					(() => {
						const themeApi = window.__mogThemeMode;
						if (!themeApi) return;

						const select = document.querySelector('[data-theme-select]');
						const picker = document.querySelector('.theme-select');
						const darkQuery = window.matchMedia('(prefers-color-scheme: dark)');

						const syncPicker = () => {
							const activeMode = document.documentElement.dataset.themeMode || 'system';
							if (select instanceof HTMLSelectElement) select.value = activeMode;
							if (picker instanceof HTMLElement) picker.dataset.themeIcon = activeMode;
						};

						if (select instanceof HTMLSelectElement) {
							select.addEventListener('change', () => {
								const mode = select.value;
								themeApi.write(mode);
								themeApi.apply(mode);
								syncPicker();
							});
						}

						darkQuery.addEventListener('change', () => {
							if ((document.documentElement.dataset.themeMode || 'system') !== 'system') return;
							themeApi.apply('system');
							syncPicker();
						});

						syncPicker();
					})();
				</script>
			)
		}
	</body>
</html>
