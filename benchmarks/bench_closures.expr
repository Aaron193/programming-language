function makeAdder(i32 n) -> fn(i32) -> i32 {
  function addOne(i32 x) -> i32 {
    return n + x;
  }
  return addOne;
}

Array<fn(i32) -> i32> funcs = [];

f64 start = clock();

for (i32 i = 0; i < 10000; i++) {
  funcs.push(makeAdder(i));
}

i32 sum = 0;
for (i32 i = 0; i < funcs.size(); i++) {
  sum += funcs[i](1);
}

f64 elapsed = clock() - start;

print(sum);
print(elapsed);
