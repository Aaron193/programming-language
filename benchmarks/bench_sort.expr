i32 n = 5000;
Array<i32> arr = [];

for (i32 value = n; value > 0; value--) {
  arr.push(value);
}

f64 start = clock();

i32 i = 1;
while (i < arr.size()) {
  i32 key = arr[i];
  i32 j = i - 1;
  bool shifting = true;

  while (j >= 0 and shifting) {
    if (arr[j] > key) {
      arr[j + 1] = arr[j];
      j = j - 1;
    } else {
      shifting = false;
    }
  }

  arr[j + 1] = key;
  i = i + 1;
}

f64 elapsed = clock() - start;

print(arr[0]);
print(arr[n - 1]);
print(elapsed);
