print("cache_handle_target_loaded")

const counter = @import("examples:counter")

fn Make(seed i64) handle<examples:counter:CounterHandle> {
  return counter.create(seed)
}

fn Read(value handle<examples:counter:CounterHandle>) i64 {
  return counter.read(value)
}

fn Add(value handle<examples:counter:CounterHandle>, delta i64) i64 {
  return counter.add(value, delta)
}
