const d Dict<str, i32> = {}

const start f64 = clock()

for (var i i32 = 0; i < 30000; i++) {
    const key str = "key" + str(i)
    d[key] = i
}

var sum i32 = 0
for (var i i32 = 0; i < 30000; i++) {
    const key str = "key" + str(i)
    sum += d[key]
}

const elapsed f64 = clock() - start

print(sum)
print(d.size())
print(elapsed)
