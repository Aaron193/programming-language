i32 value = 6;
print(value & 3);
print(value | 3);
print(value ^ 3);
print(~value);

print(1 | 6 & 3);
print(12 >> 1 & 5);
print(5 & 3 == 1);

value &= 3;
print(value);
value |= 8;
print(value);
value ^= 15;
print(value);

class Box {
	i32 bits;
}

Box box = Box();
box.bits = 12;
box.bits &= 10;
print(box.bits);

Array<i32> nums = [7, 12];
nums[1] ^= 10;
print(nums[1]);

u8 left = 12u8;
u16 right = 10u16;
print(left & right);
